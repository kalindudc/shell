<%
  # Environment & profile
  profile     = ENV.fetch("OPENCODE_PROFILE", "personal")
  personal    = (profile == "personal")
  work        = (profile == "work")

  groq_key    = ENV.fetch("GROQ_API_KEY", "")
  ollama_host = ENV.fetch("OLLAMA_HOST", "http://127.0.0.1:11434")

  ollama_models_raw = ENV.fetch("OLLAMA_MODELS", "qwen3:8b llama4:scout")
  ollama_models     = ollama_models_raw.split.map(&:strip).reject(&:empty?)

  has_groq   = personal && !groq_key.empty?
  has_ollama = !ollama_models.empty?

  # Agent overrides -- personal profile downgrades utility agents to haiku
  personal_agent_overrides = {
    "skill-health"             => "anthropic/claude-haiku-4-5",
    "pr-description-generator" => "anthropic/claude-haiku-4-5",
    "skill-improver"           => "anthropic/claude-haiku-4-5",
    "codebase-explorer"        => "anthropic/claude-haiku-4-5",
    "memory-analyzer"          => "anthropic/claude-haiku-4-5"
  }

  # Critic agents -- work profile only (personal skips multi-model consensus)
  # Each critic uses a different provider's strongest reasoning model for
  # maximum quality and diversity in consensus voting.
  critic_models = {
    "critic/claude" => "shopify-anthropic/claude-sonnet-4-6",
    "critic/gemini" => "shopify-google/gemini-3.1-pro-preview",
    "critic/gpt"    => "shopify-openai/gpt-5.4-pro",
    "critic/grok"   => "shopify-xai/grok-4.20-beta-0309-reasoning"
  }

  critic_shared = {
    "description"  => "Multi-domain critic. Evaluates findings against caller-provided criteria. Votes KEEP or REJECT.",
    "mode"         => "subagent",
    "temperature"  => 0.1,
    "steps"        => 25,
    "prompt"       => "{file:./prompts/critic.md}",
    "permission"   => {
      "external_directory" => { "~/.config/opencode/**" => "allow" },
      "edit"               => { "*" => "deny" },
      "bash"               => {
        "git diff*" => "allow",
        "git log*"  => "allow",
        "git show*" => "allow",
        "grep *"    => "allow",
        "rg *"      => "allow"
      },
      "webfetch" => "allow",
      "task"     => { "researcher" => "allow" }
    },
    "color" => "warning"
  }

  # Providers -- personal profile only (work uses Shopify-proxied models)
  providers = {}

  if has_groq
    providers["groq"] = {
      "npm"     => "@ai-sdk/openai-compatible",
      "name"    => "Groq",
      "options" => {
        "baseURL" => "https://api.groq.com/openai/v1",
        "apiKey"  => "{env:GROQ_API_KEY}"
      },
      "models" => {
        "llama-3.3-70b-versatile" => {
          "name"  => "Llama 3.3 70B",
          "limit" => { "context" => 131072, "output" => 32768 }
        },
        "llama-3.1-8b-instant" => {
          "name"  => "Llama 3.1 8B Instant",
          "limit" => { "context" => 131072, "output" => 131072 }
        }
      }
    }
  end

  if personal && has_ollama
    ollama_model_hash = {}
    ollama_models.each { |m| ollama_model_hash[m] = { "name" => m } }

    providers["ollama"] = {
      "npm"     => "@ai-sdk/openai-compatible",
      "name"    => "Ollama (local)",
      "options" => { "baseURL" => "#{ollama_host}/v1" },
      "models"  => ollama_model_hash
    }
  end
-%>
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "default_agent": "build",
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow"
    }
  },
  "share": "manual",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "build/**",
      ".git/**",
      "*.log"
    ]
  },
  "server": {
    "hostname": "127.0.0.1",
    "mdnsDomain": "opencode.local"
  },
  "agent": {
<%- if personal -%>
<%- personal_agent_overrides.each do |name, model| -%>
    "<%= name %>": { "model": "<%= model %>" },
<%- end -%>
<%- end -%>
<%- if work -%>
<%- critic_models.each do |name, model| -%>
    "<%= name %>": <%= JSON.pretty_generate(critic_shared.merge("model" => model)).gsub("\n", "\n    ") %>,
<%- end -%>
<%- end -%>
    "consensus":  { "steps": 50 },
    "researcher": { "steps": 30 }
  },
  "provider": <%= providers.empty? ? "{}" : JSON.pretty_generate(providers).gsub("\n", "\n  ") %>
}
