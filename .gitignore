.env

src/bin/cldebug

tt.*
.tests
doc/tags
debug
.repro
foo.*
*.log
data
.vim/bundle/
.vim/plugged/

home/.gitconfig
home/.config/zsh/completions/
vendor/
.bundle/
.tmp/
tmp/
test-manual.sh
node_modules/

home/.claude/settings.json

# ignore home/.claude files, with some exceptions
home/.claude/*
!home/.claude/commands/
!home/.claude/concepts/
!home/.claude/templates/
!home/.claude/agents/
!home/.claude/skills/
!home/.claude/scripts/

# ignore .claude files, with some exceptions
.claude/*
!.claude/commands/
!.claude/concepts/
!.claude/templates/
!.claude/agents/
!.claude/skills/
!.claude/scripts/

# ignore opencode files, with some exceptions
home/.config/opencode/*
!home/.config/opencode/tui.json
!home/.config/opencode/commands/
!home/.config/opencode/concepts/
!home/.config/opencode/templates/
!home/.config/opencode/agents/
!home/.config/opencode/skills/
!home/.config/opencode/scripts/
!home/.config/opencode/tools/
!home/.config/opencode/prompts/
!home/.config/opencode/plugins/
!home/.config/opencode/session-recorder.json
!home/.config/opencode/plugins.json
home/.config/opencode/**/*interview*

# SKILL_NOTES.md files are local observations, bootstrapped by src/scripts/bootstrap-skill-notes.sh
home/.config/opencode/skills/*/SKILL_NOTES.md


# ignore home/.pi files, with some exceptions
# NOTE: use home/.pi/* (not home/.pi/) so git recurses into the directory
# and honors un-ignore rules for nested paths
home/.pi/*
!home/.pi/agent/
home/.pi/agent/*
!home/.pi/agent/extensions/
!home/.pi/agent/agents/
!home/.pi/agent/skills/
!home/.pi/agent/prompts/
!home/.pi/agent/themes/
!home/.pi/agent/docs/
!home/.pi/agent/README.md
!home/.pi/agent/AGENTS.md

home/.pi/agent/extensions/shopify-proxy
home/.pi/agent/extensions/pkg
home/.pi/agent/extensions/no-sleep-while-working
home/.pi/agent/extensions/observe
home/.pi/agent/extensions/retitle
home/.pi/agent/extensions/slack
home/.pi/agent/extensions/vault
home/.pi/agent/extensions/guard

# SKILL_NOTES.md files are local observations, bootstrapped by src/scripts/bootstrap-skill-notes.sh
home/.pi/agents/skills/*/SKILL_NOTES.md
home/.agents/skills/*/SKILL_NOTES.md
