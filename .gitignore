# ignore .claude files, with some exceptions
.claude/*
!.claude/commands/
!.claude/concepts/
!.claude/templates/
!.claude/agents/
!.claude/skills/
!.claude/scripts/

home/.agents/**/*interview*

# ignore home/.pi files, with some exceptions
# NOTE: use home/.pi/* (not home/.pi/) so git recurses into the directory
# and honors un-ignore rules for nested paths
home/.pi/*
!home/.pi/agent/
home/.pi/agent/*
!home/.pi/agent/extensions/
!home/.pi/agent/agents/
!home/.pi/agent/skills/
!home/.pi/agent/prompts/
!home/.pi/agent/themes/
!home/.pi/agent/docs/
!home/.pi/agent/README.md
!home/.pi/agent/AGENTS.md
home/.pi/agent/**/*interview*

