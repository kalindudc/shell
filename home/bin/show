#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/cli_common.sh
source "${SCRIPT_DIR}/lib/cli_common.sh"

TOOL_NAME="show"
CONF_DIR="$(cli_conf_dir "${TOOL_NAME}")"
CONF_PATH="${CONF_DIR}/show_conf.json"

help() {
  cli_print_help "${TOOL_NAME}" "quickly store and retrieve text" \
    "<key>|Retrieve text stored at <key>" \
    "init|Initialize configuration file" \
    "list|List currently stored keys" \
    "add <key> <value>|Store a key/value pair" \
    "delete <key>|Delete a key" \
    "-A, --all|Show all stored data" \
    "-h, --help|Show this help"
  printf "Configuration file: %s\n" "${CONF_PATH}"
}

init() {
  if [[ -f "${CONF_PATH}" ]]; then
    printf "%s already exists, skipping init\n" "${CONF_PATH}"
  else
    cli_ensure_conf "${TOOL_NAME}" "show_conf.json:{}"
    printf "Configuration file generated at %s\n" "${CONF_PATH}"
  fi
}

list() {
  cli_require_conf "${TOOL_NAME}"
  jq -r 'keys[]' "${CONF_PATH}" | nl
}

# handle input
if [[ $# -lt 1 ]]; then
  help
  exit 0
fi

case "$1" in
  init)        init; exit 0 ;;
  list)        list; exit 0 ;;
  -h|--help)   help; exit 0 ;;
esac

cli_require_conf "${TOOL_NAME}"

if [[ $1 == "add" ]]; then
  if [[ $# -lt 3 ]]; then
    printf "Error: invalid number of parameters for 'add'\n\n" >&2
    help
    exit 1
  fi
  new_json=$(jq -c ".\"$2\"=\"$3\"" "${CONF_PATH}")
  printf '%s' "${new_json}" > "${CONF_PATH}"
  printf "Added \"%s\" to retrieve \"%s\"\n" "$2" "$3"
elif [[ $1 == "delete" ]]; then
  if [[ $# -lt 2 ]]; then
    printf "Error: invalid number of parameters for 'delete'\n\n" >&2
    help
    exit 1
  fi
  new_json=$(jq -c "del(.\"$2\")" "${CONF_PATH}")
  printf '%s' "${new_json}" > "${CONF_PATH}"
  printf "Deleted \"%s\"\n" "$2"
elif [[ $1 == "-A" || $1 == "--all" ]]; then
  jq "." "${CONF_PATH}"
else
  json_data=$(jq -r ".\"$1\"" "${CONF_PATH}")
  printf '%s\n' "${json_data}"
fi
