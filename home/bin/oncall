#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/cli_common.sh
source "${SCRIPT_DIR}/lib/cli_common.sh"

TOOL_NAME="oncall"
CONF_DIR="$(cli_conf_dir "${TOOL_NAME}")"
CONF_PATH="${CONF_DIR}/oncall_conf.json"

help() {
  cli_print_help "${TOOL_NAME}" "manage oncall duties" \
    "(no args)|View accumulated days off" \
    "init|Initialize configuration file" \
    "record, r|Record an oncall shift" \
    "use, u <float?>|Use accumulated days off" \
    "--dayoffs-per-shift <float>|Set days off per shift (default: 1)" \
    "--reset|Reset all accumulated days" \
    "-h, --help|Show this help"
  printf "Configuration file: %s\n" "${CONF_PATH}"
}

init() {
  if [[ -f "${CONF_PATH}" ]]; then
    printf "%s already exists, skipping init\n" "${CONF_PATH}"
  else
    cli_ensure_conf "${TOOL_NAME}" "oncall_conf.json:{\"dayoffs\":0,\"dayoffs_per_shift\":1}"
    printf "Configuration file generated at %s\n" "${CONF_PATH}"
  fi
}

show_status() {
  printf "You have %s days off accumulated\n" "$(cli_color cyan "${dayoffs}")"
  printf "You will be taking %s days off per shift\n" "$(cli_color yellow "${dayoffs_per_shift}")"
}

update_config() {
  if [[ $# -ne 2 ]]; then
    printf "update_config() expects 2 arguments\n" >&2
    exit 1
  fi
  printf '{"dayoffs":%s,"dayoffs_per_shift":%s}' "$1" "$2" > "${CONF_PATH}"
}

# Handle help/init before requiring conf
case "${1:-}" in
  -h|--help|help) help; exit 0 ;;
  init)           init; exit 0 ;;
esac

cli_require_conf "${TOOL_NAME}"

dayoffs=$(jq '.dayoffs' "${CONF_PATH}")
dayoffs_per_shift=$(jq '.dayoffs_per_shift' "${CONF_PATH}")

if [[ $# -lt 1 ]]; then
  show_status
  exit 0
fi

case "$1" in
  record|r)
    dayoffs=$(printf "%s + %s" "${dayoffs}" "${dayoffs_per_shift}" | bc)
    update_config "${dayoffs}" "${dayoffs_per_shift}"
    printf "You have %s days off accumulated\n" "$(cli_color cyan "${dayoffs}")"
    ;;
  use|u)
    days_to_take="${2:-${dayoffs_per_shift}}"
    new_dayoffs=$(printf "%s - %s" "${dayoffs}" "${days_to_take}" | bc)
    if [[ $(bc <<< "${new_dayoffs} < 0") -eq 1 ]]; then
      printf "You don't have enough days off to take\n" >&2
      show_status
      exit 1
    fi
    update_config "${new_dayoffs}" "${dayoffs_per_shift}"
    printf "You have %s days off remaining\n" "$(cli_color cyan "${new_dayoffs}")"
    ;;
  --reset)
    update_config 0 1
    printf "Reset...\n"
    dayoffs=0
    dayoffs_per_shift=1
    show_status
    ;;
  --dayoffs-per-shift)
    if [[ $# -ne 2 ]]; then
      printf "usage: %s --dayoffs-per-shift <float>\n" "${TOOL_NAME}" >&2
      help
      exit 1
    fi
    dayoffs_per_shift="$2"
    update_config "${dayoffs}" "${dayoffs_per_shift}"
    show_status
    ;;
  *)
    printf "Error: invalid option '%s'\n\n" "$1" >&2
    help
    exit 1
    ;;
esac
