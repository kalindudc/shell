# Configuration template
# This file is auto-generated during setup by src/setup.sh (prompt_git_config function)
# Copy this to .env and fill in your values, or run ./install.sh to generate automatically

# --- Git ---
GIT_EMAIL=<git-email>
GIT_NAME="<git-name>"
GIT_SIGNING_KEY=<git-signing-key>

# --- opencode.json generator (task generate:opencode) ---
# Profile controls which model overrides are applied.
#   personal  (default) — cost-optimised; uses Groq critics when GROQ_API_KEY is set
OPENCODE_PROFILE=personal

# Groq API key — required for Groq critic models on the personal profile.
# Free account at https://console.groq.com/keys (no payment required for dev plan).
# Leave empty or unset to fall back to anthropic/claude-haiku-4-5 for critics.
GROQ_API_KEY=

# Ollama base URL (default: http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# Space-separated Ollama model tags to include in the provider block.
# Set to "" to omit the ollama provider block entirely.
# OLLAMA_MODELS=qwen3:8b llama4:scout
